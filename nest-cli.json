{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "templates/**/*"
      },
      {
        "include": "i18n/**/*",
        "outDir": "dist/i18n"
      }
    ],
    "watchAssets": true,
    "deleteOutDir": true
  }
}
